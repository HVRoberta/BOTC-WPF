<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BrushCanvasBackground" Color="{StaticResource ColorCanvasBackground}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceAlt" Color="{StaticResource ColorSurfaceAlt}" />
    <SolidColorBrush x:Key="BrushBorderStrong" Color="{StaticResource ColorBorderStrong}" />
    <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource ColorBorderSubtle}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentForeground" Color="{StaticResource ColorAccentForeground}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushBadgeBackground" Color="{StaticResource ColorBadgeBackground}" />
    <SolidColorBrush x:Key="BrushBadgeForeground" Color="{StaticResource ColorBadgeForeground}" />
    <SolidColorBrush x:Key="BrushErrorBackground" Color="{StaticResource ColorErrorBackground}" />
    <SolidColorBrush x:Key="BrushErrorForeground" Color="{StaticResource ColorErrorForeground}" />
    <SolidColorBrush x:Key="BrushDangerSurface" Color="{StaticResource ColorDangerSurface}" />
    <SolidColorBrush x:Key="BrushDangerBorder" Color="{StaticResource ColorDangerBorder}" />
    <SolidColorBrush x:Key="BrushInfoBackground" Color="{StaticResource ColorInfoBackground}" />
    <SolidColorBrush x:Key="BrushInfoForeground" Color="{StaticResource ColorInfoForeground}" />
    <SolidColorBrush x:Key="BrushBusy" Color="{StaticResource ColorBusy}" />
</ResourceDictionary>

