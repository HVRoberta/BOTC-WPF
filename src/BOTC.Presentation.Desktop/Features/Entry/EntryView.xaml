<UserControl x:Class="BOTC.Presentation.Desktop.Features.Entry.EntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:BOTC.Presentation.Desktop.Features.Entry.Shared.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200">
    <Grid>
        
        <!-- Background -->
        <Grid.Background>
            <ImageBrush ImageSource="/BOTC.Presentation.Desktop;component/Shared/Assets/entry-background.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>
        
        <!-- Dark overlay -->
        <Border Background="#66000000" />
        
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="900">
            
            <!-- Main content -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="BLOOD ON THE CLOCKTOWER"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="#E8C26A"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            
            <!-- Name label -->
            <TextBlock Grid.Row="2"
                       Text="ENTER YOUR NAME"
                       FontSize="18"
                       Foreground="#E7DDD0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,4"/>
            
            <!-- Name input -->
            <Border Grid.Row="4"
                    Width="460"
                    Height="68"
                    Background="#E6D6B3"
                    BorderBrush="#6F563B"
                    BorderThickness="3"
                    CornerRadius="8"
                    Padding="18,10">
                <Grid>
                    <TextBox x:Name="NameTextBox" 
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="24"
                             FontWeight="SemiBold"
                             Foreground="#2A1F17"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="#2A1F17"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             TextAlignment="Center"
                             MaxLength="24">
                        
                        <!-- Enter = Join -->
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding JoinGameCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>
            </Border>
            
            <!-- Validation message -->
            <TextBlock Grid.Row="4"
                       Text="{Binding ValidationMessage}"
                       Foreground="#FF8C8C"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Visibility="{Binding HasValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Margin="0,2,0,0" />
            
            <!-- Buttons -->
            <Grid Grid.Row="8"
                  HorizontalAlignment="Center"
                  Margin="0,8,0,0">
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- HOST -->
                <controls:WaxSealButton Grid.Column="0"
                                        Width="220"
                                        Height="220"
                                        TopText="HOST GAME"
                                        BottomText="HOST GAME"
                                        BackgroundImage="/BOTC.Presentation.Desktop;component/Features/Entry/Shared/Assets/host-seal.png"
                                        GlowBrush="#66FF4040"
                                        ForegroundBrush="#E8C26A"
                                        BorderBrushColor="#E8C26A"
                                        Command="{Binding HostGameCommand}" />

                <!-- JOIN -->
                <controls:WaxSealButton Grid.Column="2"
                                        Width="220"
                                        Height="220"
                                        TopText="JOIN GAME"
                                        BottomText="JOIN GAME"
                                        BackgroundImage="/BOTC.Presentation.Desktop;component/Features/Entry/Shared/Assets/join-seal.png"
                                        GlowBrush="#6640A0FF"
                                        ForegroundBrush="#D9D9D9"
                                        BorderBrushColor="#AAB7C8"
                                        FallbackFill="#2B2E3A"
                                        Command="{Binding JoinGameCommand}" />
            </Grid>
            
            <!-- Status (debug / later loading) -->
            <TextBlock Grid.Row="7"
                       Text="{Binding StatusMessage}"
                       Foreground="#BBBBBB"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</UserControl>
