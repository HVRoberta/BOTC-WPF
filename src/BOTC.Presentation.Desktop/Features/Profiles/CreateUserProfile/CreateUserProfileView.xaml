<UserControl x:Class="BOTC.Presentation.Desktop.Features.Profiles.CreateUserProfile.CreateUserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BOTC.Presentation.Desktop.Features.Profiles.CreateUserProfile"
             mc:Ignorable="d">
    <Border Width="520"
            Padding="28"
            CornerRadius="18"
            Background="#CC141824"
            BorderBrush="#C89B4A"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" 
                       Text="Create New Profile"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#F1C36A"
                       Margin="0,0,0,10" />
            
            <TextBlock Grid.Row="1"
                       Text="Choose a name for the new player profile."
                       HorizontalAlignment="Center"
                       FontSize="16"
                       Foreground="#F2E5C8"
                       TextAlignment="Center"/>
            
            <StackPanel Grid.Row="3">
                <TextBlock Text="Profile Name"
                           Margin="0,0,0,6"
                           FontSize="15"
                           Foreground="#E8D8B5"/>

                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         Height="42"
                         Padding="10,6"
                         FontSize="18"
                         Background="#F3E6C8"
                         Foreground="#1A1A1A"
                         BorderBrush="#C89B4A"
                         BorderThickness="1.5"/>
            </StackPanel>
            
            <TextBlock Grid.Row="5"
                       Text="{Binding ValidationMessage}"
                       Foreground="#F08A7E"
                       FontSize="14"
                       TextWrapping="Wrap"/>
            
            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0"
                        Height="50"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Background="#2B3240"
                        Foreground="#F3E6C8"
                        BorderBrush="#6F7A8A"
                        BorderThickness="1.5"
                        Cursor="Hand"/>

                <Button Grid.Column="2"
                        Height="50"
                        Command="{Binding SaveCommand}"
                        Content="Create Profile"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Background="#4E2A18"
                        Foreground="#F7E6BF"
                        BorderBrush="#C89B4A"
                        BorderThickness="2"
                        Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
