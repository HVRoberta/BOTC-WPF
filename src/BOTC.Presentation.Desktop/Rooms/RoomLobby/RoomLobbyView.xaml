<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.RoomLobby.RoomLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:roomLobby="clr-namespace:BOTC.Presentation.Desktop.Rooms.RoomLobby"
             xmlns:sharedControls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="760">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/RoomLobbyStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <sharedControls:PageHeader Grid.Row="0"
                                   Title="Room lobby"
                                   Subtitle="Manage the room, monitor live lobby updates, and keep players ready for the next game flow.">
            <sharedControls:PageHeader.ActionContent>
                <Button VerticalAlignment="Top"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        Content="Refresh now" />
            </sharedControls:PageHeader.ActionContent>
        </sharedControls:PageHeader>

        <sharedControls:SectionCard Grid.Row="2"
                                    Title="Room status"
                                    Subtitle="Connection health, identity details, and current lobby snapshot metadata.">
            <sharedControls:SectionCard.BodyContent>
                <StackPanel>
                    <WrapPanel>
                        <sharedControls:StatusBadge Text="{Binding RoomCode, StringFormat=Room {0}}" />
                        <sharedControls:StatusBadge Text="{Binding RoomStatus}" />
                        <Border Style="{StaticResource RealtimeStateBadgeBorderStyle}">
                            <TextBlock Style="{StaticResource RealtimeStateBadgeTextStyle}"
                                       Text="{Binding RealtimeStateText}" />
                        </Border>
                    </WrapPanel>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Style="{StaticResource LobbyMetadataGroupStyle}">
                            <TextBlock Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Host" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding HostDisplayName}" />

                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="You" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding CurrentUserDisplayName}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Style="{StaticResource LobbyMetadataGroupStyle}">
                            <TextBlock Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Your role" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding CurrentUserRole}" />

                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Last successful sync" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding LastSuccessfulRefreshText}" />
                        </StackPanel>
                    </Grid>

                    <sharedControls:ErrorBanner Margin="0,10,0,0"
                                                Message="{Binding ScreenMessage}"
                                                Kind="{Binding ScreenMessageKind}"
                                                Show="{Binding HasScreenMessage}" />

                    <sharedControls:ErrorBanner Margin="0,10,0,0"
                                                Message="{Binding RealtimeMessage}"
                                                Kind="{Binding RealtimeMessageKind}"
                                                Show="{Binding HasRealtimeMessage}" />

                    <sharedControls:LoadingPanel Margin="0,12,0,0"
                                                 Text="{Binding BusyText}"
                                                 IsBusy="{Binding IsBusy}" />
                </StackPanel>
            </sharedControls:SectionCard.BodyContent>
        </sharedControls:SectionCard>

        <sharedControls:SectionCard Grid.Row="4"
                                    Title="Players"
                                    Subtitle="{Binding PlayerCountSummary}">
            <sharedControls:SectionCard.BodyContent>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type roomLobby:LobbyPlayerItemViewModel}">
                                <Border Style="{StaticResource LobbyPlayerCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Style="{StaticResource LobbyPlayerSeatBadgeStyle}">
                                            <TextBlock Style="{StaticResource BadgeTextStyle}"
                                                       Text="{Binding SeatNumber}" />
                                        </Border>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource LobbyPlayerNameTextStyle}"
                                                       Text="{Binding DisplayName}" />
                                            <TextBlock Style="{StaticResource LobbyPlayerSubtitleTextStyle}"
                                                       Text="{Binding RoleLabel}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                                            <sharedControls:StatusBadge Margin="0"
                                                                        Text="You"
                                                                        Visibility="{Binding IsCurrentUser, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <sharedControls:StatusBadge Margin="8,0,0,0"
                                                                        Text="Host"
                                                                        Visibility="{Binding IsHost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </sharedControls:SectionCard.BodyContent>
        </sharedControls:SectionCard>

        <sharedControls:ActionBar Grid.Row="6">
            <sharedControls:ActionBar.LeadingContent>
                <StackPanel Orientation="Horizontal">
                    <Button Margin="0,0,12,0"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding LeaveRoomCommand}"
                            Content="Leave room" />

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BackToCreateRoomCommand}"
                            Content="Back to room setup" />
                </StackPanel>
            </sharedControls:ActionBar.LeadingContent>
        </sharedControls:ActionBar>
    </Grid>
</UserControl>
