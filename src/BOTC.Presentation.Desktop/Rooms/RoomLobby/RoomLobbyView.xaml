<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.RoomLobby.RoomLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:roomLobby="clr-namespace:BOTC.Presentation.Desktop.Rooms.RoomLobby"
             xmlns:sharedControls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="760">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <sharedControls:SectionCard Title="Room lobby"
                                    Subtitle="Manage the room, monitor live lobby updates, and keep players ready for the next game flow."
                                    Grid.Row="0">
            <sharedControls:SectionCard.HeaderActionContent>
                <Button VerticalAlignment="Top"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        Content="Refresh now" />
            </sharedControls:SectionCard.HeaderActionContent>
            <sharedControls:SectionCard.BodyContent>
                <StackPanel>
                    <WrapPanel>
                        <sharedControls:StatusBadge Text="{Binding RoomCode, StringFormat=Room {0}}" />
                        <sharedControls:StatusBadge Text="{Binding RoomStatus}" />
                        <sharedControls:StatusBadge Text="{Binding RealtimeStateText}" />
                    </WrapPanel>

                    <sharedControls:ErrorBanner Margin="0,10,0,0"
                                                Message="{Binding ScreenMessage}"
                                                Kind="{Binding ScreenMessageKind}"
                                                Show="{Binding HasScreenMessage}" />

                    <sharedControls:LoadingPanel Margin="0,12,0,0"
                                                 Text="{Binding BusyText}"
                                                 IsBusy="{Binding IsBusy}" />
                </StackPanel>
            </sharedControls:SectionCard.BodyContent>
        </sharedControls:SectionCard>

        <sharedControls:SectionCard Grid.Row="2"
                                    Title="Players"
                                    Subtitle="{Binding Players.Count, StringFormat=Players currently in lobby: {0}}">
            <sharedControls:SectionCard.HeaderActionContent>
                <TextBlock VerticalAlignment="Bottom"
                           Style="{StaticResource MutedTextStyle}"
                           Text="Realtime and manual refresh stay in sync." />
            </sharedControls:SectionCard.HeaderActionContent>
            <sharedControls:SectionCard.BodyContent>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type roomLobby:LobbyPlayerItemViewModel}">
                                <Border Style="{StaticResource PlayerCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="{StaticResource FontSizeValue}" />
                                                        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHost}" Value="True">
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="Room host"
                                                       Visibility="{Binding IsHost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>

                                        <sharedControls:StatusBadge Grid.Column="1"
                                                                    Margin="12,0,0,0"
                                                                    Text="Host"
                                                                    Visibility="{Binding IsHost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </sharedControls:SectionCard.BodyContent>
        </sharedControls:SectionCard>

        <sharedControls:ActionBar Grid.Row="4">
            <sharedControls:ActionBar.LeadingContent>
                <StackPanel Orientation="Horizontal">
                    <Button Margin="0,0,12,0"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding LeaveRoomCommand}"
                            Content="Leave room" />

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BackToCreateRoomCommand}"
                            Content="Back to room setup" />
                </StackPanel>
            </sharedControls:ActionBar.LeadingContent>
        </sharedControls:ActionBar>
    </Grid>
</UserControl>
