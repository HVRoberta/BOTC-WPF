<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.RoomLobby.RoomLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:roomLobby="clr-namespace:BOTC.Presentation.Desktop.Rooms.RoomLobby"
             xmlns:sharedControls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="760">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource RoomScreenCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource RoomScreenTitleTextStyle}"
                                   Text="Room lobby" />
                        <TextBlock Style="{StaticResource RoomScreenSubtitleTextStyle}"
                                   Text="Manage the room, monitor live lobby updates, and keep players ready for the next game flow." />
                    </StackPanel>

                    <Button Grid.Column="1"
                            VerticalAlignment="Top"
                            Style="{StaticResource RoomSecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Content="Refresh now" />
                </Grid>

                <WrapPanel Grid.Row="2">
                    <Border Style="{StaticResource RoomStatusBadgeBorderStyle}">
                        <TextBlock Style="{StaticResource RoomStatusBadgeTextStyle}"
                                   Text="{Binding RoomCode, StringFormat=Room {0}}" />
                    </Border>

                    <Border Style="{StaticResource RoomStatusBadgeBorderStyle}">
                        <TextBlock Style="{StaticResource RoomStatusBadgeTextStyle}"
                                   Text="{Binding RoomStatus}" />
                    </Border>

                    <Border Style="{StaticResource RoomStatusBadgeBorderStyle}">
                        <TextBlock Style="{StaticResource RoomStatusBadgeTextStyle}"
                                   Text="{Binding RealtimeStateText}" />
                    </Border>
                </WrapPanel>

                <sharedControls:StateBanner Grid.Row="4"
                                            Message="{Binding ScreenMessage}"
                                            Kind="{Binding ScreenMessageKind}"
                                            Show="{Binding HasScreenMessage}" />

                <sharedControls:BusyIndicator Grid.Row="6"
                                              Text="{Binding BusyText}"
                                              IsBusy="{Binding IsBusy}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource RoomSectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource RoomSectionTitleTextStyle}"
                                   Text="Players" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource RoomMutedTextStyle}"
                                   Text="{Binding Players.Count, StringFormat=Players currently in lobby: {0}}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Bottom"
                               Style="{StaticResource RoomMutedTextStyle}"
                               Text="Realtime and manual refresh stay in sync." />
                </Grid>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type roomLobby:LobbyPlayerItemViewModel}">
                                <Border Style="{StaticResource RoomPlayerCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="15"
                                                       Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHost}" Value="True">
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource RoomMutedTextStyle}"
                                                       Text="Room host"
                                                       Visibility="{Binding IsHost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Margin="12,0,0,0"
                                                Style="{StaticResource RoomStatusBadgeBorderStyle}"
                                                Visibility="{Binding IsHost, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Style="{StaticResource RoomStatusBadgeTextStyle}"
                                                       Text="Host" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    Style="{StaticResource RoomActionRowStyle}">
            <Button Margin="0,0,12,0"
                    Style="{StaticResource RoomDangerButtonStyle}"
                    Command="{Binding LeaveRoomCommand}"
                    Content="Leave room" />

            <Button Style="{StaticResource RoomSecondaryButtonStyle}"
                    Command="{Binding BackToCreateRoomCommand}"
                    Content="Back to room setup" />
        </StackPanel>
    </Grid>
</UserControl>
