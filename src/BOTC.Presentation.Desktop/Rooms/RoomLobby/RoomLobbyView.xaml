<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.RoomLobby.RoomLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:roomLobby="clr-namespace:BOTC.Presentation.Desktop.Rooms.RoomLobby"
             xmlns:sharedControls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="760">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/RoomLobbyStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <sharedControls:PageHeader Grid.Row="0"
                                   Title="Room lobby"
                                   Subtitle="Manage the room, monitor live lobby updates, and keep players ready for the next game flow.">
            <sharedControls:PageHeader.ActionContent>
                <Button VerticalAlignment="Top"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        Content="Refresh now" />
            </sharedControls:PageHeader.ActionContent>
        </sharedControls:PageHeader>

        <sharedControls:SectionCard Grid.Row="2"
                                    Title="Room status"
                                    Subtitle="Current lobby status, realtime connection, and player identity details.">
            <sharedControls:SectionCard.BodyContent>
                <StackPanel>
                    <WrapPanel Style="{StaticResource LobbySummaryBadgesWrapStyle}">
                        <StackPanel Margin="0,0,14,8">
                            <TextBlock Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Room" />
                            <sharedControls:StatusBadge Margin="0,4,0,0" Text="{Binding RoomCode, StringFormat=Code {0}}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,14,8">
                            <TextBlock Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Lobby" />
                            <sharedControls:StatusBadge Margin="0,4,0,0" Text="{Binding RoomStatus}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Realtime" />
                            <Border Margin="0,4,0,0" Style="{StaticResource RealtimeStateBadgeBorderStyle}">
                                <TextBlock Style="{StaticResource RealtimeStateBadgeTextStyle}"
                                           Text="{Binding RealtimeStateText}" />
                            </Border>
                        </StackPanel>
                    </WrapPanel>

                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,8,10,0"
                                Style="{StaticResource LobbySummaryIdentityCardStyle}"
                                Background="{StaticResource BrushInfoBackground}"
                                BorderBrush="{StaticResource BrushInfoForeground}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LobbySummaryIdentityTitleTextStyle}" Text="You" />
                                <TextBlock Style="{StaticResource LobbySummaryIdentityNameTextStyle}" Text="{Binding CurrentUsername}" />
                                <TextBlock Style="{StaticResource LobbySummaryIdentityRoleTextStyle}" Text="{Binding CurrentUserRole}" />
                                <TextBlock Style="{StaticResource LobbySummaryIdentityRoleTextStyle}" Text="{Binding CurrentUserReadyStateText}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Style="{StaticResource LobbyMetadataGroupStyle}">
                            <Border Style="{StaticResource LobbySummaryIdentityCardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource LobbySummaryIdentityTitleTextStyle}" Text="Host" />
                                    <TextBlock Style="{StaticResource LobbySummaryIdentityNameTextStyle}" Text="{Binding HostName}" />
                                    <TextBlock Style="{StaticResource LobbySummaryIdentityRoleTextStyle}" Text="Room owner" />
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Last successful sync" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding LastSuccessfulRefreshText}" />

                            <TextBlock Margin="0,8,0,0" Style="{StaticResource LobbyMetadataLabelTextStyle}" Text="Ready players" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding NonHostReadinessSummary}" />
                            <TextBlock Margin="0,2,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding StartEligibilityHint}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Style="{StaticResource LobbyMessagesGroupStyle}"
                                Visibility="{Binding HasAnyStatusUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource LobbyMessagesHeadingTextStyle}" Text="Updates" />

                        <sharedControls:ErrorBanner Message="{Binding ScreenMessage}"
                                                    Kind="{Binding ScreenMessageKind}"
                                                    Show="{Binding HasScreenMessage}" />

                        <sharedControls:ErrorBanner Margin="0,8,0,0"
                                                    Message="{Binding RealtimeMessage}"
                                                    Kind="{Binding RealtimeMessageKind}"
                                                    Show="{Binding HasRealtimeMessage}" />

                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Visibility="{Binding ShowLastSuccessfulLobbyHint, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Text="Showing the last successful lobby snapshot while newer updates are unavailable." />

                        <sharedControls:LoadingPanel Margin="0,8,0,0"
                                                     Text="{Binding BusyText}"
                                                     IsBusy="{Binding IsBusy}" />
                    </StackPanel>
                </StackPanel>
            </sharedControls:SectionCard.BodyContent>
        </sharedControls:SectionCard>

        <sharedControls:SectionCard Grid.Row="4"
                                    Title="Players"
                                    Subtitle="{Binding PlayerCountSummary}">
            <sharedControls:SectionCard.BodyContent>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type roomLobby:LobbyPlayerItemViewModel}">
                                <Border Style="{StaticResource LobbyPlayerCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Style="{StaticResource LobbyPlayerSeatBadgeStyle}">
                                            <TextBlock Style="{StaticResource LobbyPlayerSeatTextStyle}"
                                                       Text="{Binding SeatNumber}" />
                                        </Border>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource LobbyPlayerNameTextStyle}"
                                                       Text="{Binding Name}" />
                                            <TextBlock Style="{StaticResource LobbyPlayerSubtitleTextStyle}"
                                                       Text="{Binding RoleLabel}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                                            <sharedControls:StatusBadge Margin="0"
                                                                        Text="You"
                                                                        Visibility="{Binding IsCurrentUser, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <sharedControls:StatusBadge Margin="8,0,0,0"
                                                                        Text="Host">
                                                <sharedControls:StatusBadge.Style>
                                                    <Style TargetType="{x:Type sharedControls:StatusBadge}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHost}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsHost}" Value="True" />
                                                                    <Condition Binding="{Binding IsCurrentUser}" Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </sharedControls:StatusBadge.Style>
                                            </sharedControls:StatusBadge>

                                            <Border Style="{StaticResource LobbyPlayerReadyBadgeBorderStyle}">
                                                <TextBlock Style="{StaticResource LobbyPlayerReadyBadgeTextStyle}"
                                                           Text="{Binding ReadyLabel}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </sharedControls:SectionCard.BodyContent>
        </sharedControls:SectionCard>

        <sharedControls:ActionBar Grid.Row="6">
            <sharedControls:ActionBar.LeadingContent>
                <StackPanel Orientation="Horizontal">
                    <Button Margin="0,0,12,0"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding LeaveRoomCommand}"
                            Content="Leave room" />

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BackToCreateRoomCommand}"
                            Content="Back to room setup" />
                </StackPanel>
            </sharedControls:ActionBar.LeadingContent>

            <sharedControls:ActionBar.TrailingContent>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ToggleReadyCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Content" Value="Mark ready" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentUserReady}" Value="True">
                                        <Setter Property="Content" Value="Mark not ready" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCurrentUserHost}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Margin="12,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartGameCommand}"
                            Content="Start game"
                            Visibility="{Binding IsCurrentUserHost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </sharedControls:ActionBar.TrailingContent>
        </sharedControls:ActionBar>
    </Grid>
</UserControl>
