<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:roomLobby="clr-namespace:BOTC.Presentation.Desktop.Rooms.RoomLobby">
    <Style x:Key="RealtimeStateBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
        <Setter Property="Background" Value="{StaticResource BrushBadgeBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushInfoBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RealtimeConnectionState}" Value="{x:Static roomLobby:RealtimeConnectionState.Connecting}">
                <Setter Property="Background" Value="{StaticResource BrushInfoBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RealtimeConnectionState}" Value="{x:Static roomLobby:RealtimeConnectionState.Reconnecting}">
                <Setter Property="Background" Value="{StaticResource BrushInfoBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RealtimeConnectionState}" Value="{x:Static roomLobby:RealtimeConnectionState.Disconnected}">
                <Setter Property="Background" Value="{StaticResource BrushErrorBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushErrorForeground}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyMetadataGroupStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,10,12,0" />
    </Style>

    <Style x:Key="LobbySummaryBadgesWrapStyle" TargetType="WrapPanel">
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <Style x:Key="LobbySummaryIdentityCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSection}" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style x:Key="LobbySummaryIdentityTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="LobbySummaryIdentityNameTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ValueTextStyle}">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="LobbySummaryIdentityRoleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <Style x:Key="LobbyMessagesGroupStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,10,0,0" />
    </Style>

    <Style x:Key="LobbyMetadataLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="LobbyMessagesHeadingTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LobbyMetadataLabelTextStyle}">
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="RealtimeStateBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RealtimeConnectionState}" Value="{x:Static roomLobby:RealtimeConnectionState.Connecting}">
                <Setter Property="Foreground" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RealtimeConnectionState}" Value="{x:Static roomLobby:RealtimeConnectionState.Reconnecting}">
                <Setter Property="Foreground" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RealtimeConnectionState}" Value="{x:Static roomLobby:RealtimeConnectionState.Disconnected}">
                <Setter Property="Foreground" Value="{StaticResource BrushErrorForeground}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyPlayerCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSection}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushInfoBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyPlayerSeatBadgeStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushInfoForeground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyPlayerNameTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ValueTextStyle}">
        <Setter Property="FontWeight" Value="Normal" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsHost}" Value="True">
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyPlayerSubtitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <Style x:Key="LobbyPlayerReadyBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
        <Setter Property="Margin" Value="8,0,0,0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsReady}" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushInfoBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushInfoForeground}" />
                <Setter Property="BorderThickness" Value="1" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsReady}" Value="False">
                <Setter Property="Background" Value="{StaticResource BrushSurface}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
                <Setter Property="BorderThickness" Value="1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyPlayerReadyBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsReady}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrushInfoForeground}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsReady}" Value="False">
                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LobbyPlayerSeatTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrushAccentForeground}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>



