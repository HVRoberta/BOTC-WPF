<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:createRoom="clr-namespace:BOTC.Presentation.Desktop.Rooms.CreateRoom"
                    xmlns:joinRoom="clr-namespace:BOTC.Presentation.Desktop.Rooms.JoinRoom"
                    xmlns:roomLobby="clr-namespace:BOTC.Presentation.Desktop.Rooms.RoomLobby">
    <DataTemplate DataType="{x:Type createRoom:CreateRoomViewModel}">
        <createRoom:CreateRoomView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type joinRoom:JoinRoomViewModel}">
        <joinRoom:JoinRoomView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type roomLobby:RoomLobbyViewModel}">
        <roomLobby:RoomLobbyView />
    </DataTemplate>
</ResourceDictionary>

