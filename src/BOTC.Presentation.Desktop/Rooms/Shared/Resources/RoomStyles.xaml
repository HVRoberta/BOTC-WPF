<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <SolidColorBrush x:Key="RoomWindowBackgroundBrush" Color="#FFF5F7FB" />
    <SolidColorBrush x:Key="RoomCardBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="RoomCardBorderBrush" Color="#FFD9E1EC" />
    <SolidColorBrush x:Key="RoomSectionBorderBrush" Color="#FFE4EAF3" />
    <SolidColorBrush x:Key="RoomAccentBrush" Color="#FF365C7D" />
    <SolidColorBrush x:Key="RoomAccentForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="RoomMutedForegroundBrush" Color="#FF5B6573" />
    <SolidColorBrush x:Key="RoomBadgeBackgroundBrush" Color="#FFEAF0F7" />
    <SolidColorBrush x:Key="RoomBadgeForegroundBrush" Color="#FF31465A" />
    <SolidColorBrush x:Key="RoomErrorBackgroundBrush" Color="#FFFCECEE" />
    <SolidColorBrush x:Key="RoomErrorForegroundBrush" Color="#FF8C2231" />
    <SolidColorBrush x:Key="RoomInfoBackgroundBrush" Color="#FFE9F3FF" />
    <SolidColorBrush x:Key="RoomInfoForegroundBrush" Color="#FF1B4E80" />
    <SolidColorBrush x:Key="RoomBusyBrush" Color="#FF50708F" />

    <CornerRadius x:Key="RoomCardCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="RoomBadgeCornerRadius">999</CornerRadius>
    <Thickness x:Key="RoomScreenPadding">24</Thickness>
    <Thickness x:Key="RoomSectionPadding">18</Thickness>

    <Style x:Key="RoomScreenCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource RoomCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource RoomCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RoomCardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource RoomScreenPadding}" />
    </Style>

    <Style x:Key="RoomSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource RoomCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource RoomSectionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="{StaticResource RoomSectionPadding}" />
    </Style>

    <Style x:Key="RoomScreenTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="RoomScreenSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Foreground" Value="{StaticResource RoomMutedForegroundBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Style.Triggers>
            <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="Text" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RoomSectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="RoomFieldLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FF26313E" />
    </Style>

    <Style x:Key="RoomMutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource RoomMutedForegroundBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="RoomValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="RoomTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="RoomActionRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>

    <Style x:Key="RoomPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="136" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource RoomAccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource RoomAccentForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource RoomAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="RoomSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="136" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource RoomCardBackgroundBrush}" />
        <Setter Property="Foreground" Value="#FF243344" />
        <Setter Property="BorderBrush" Value="{StaticResource RoomCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="RoomDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource RoomSecondaryButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource RoomErrorForegroundBrush}" />
        <Setter Property="BorderBrush" Value="#FFD8ABB2" />
        <Setter Property="Background" Value="#FFFFF7F8" />
    </Style>

    <Style x:Key="RoomStatusBadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource RoomBadgeBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RoomBadgeCornerRadius}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="RoomStatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource RoomBadgeForegroundBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="RoomPlayerCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFF9FBFD" />
        <Setter Property="BorderBrush" Value="{StaticResource RoomSectionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="RoomBusyProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="8" />
        <Setter Property="IsIndeterminate" Value="True" />
        <Setter Property="Foreground" Value="{StaticResource RoomBusyBrush}" />
    </Style>
</ResourceDictionary>

