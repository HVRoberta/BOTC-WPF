<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PageSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Style.Triggers>
            <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="Text" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSectionTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeValue}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushBadgeForeground}" />
    </Style>

    <Style x:Key="RoomScreenTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PageTitleTextStyle}" />
    <Style x:Key="RoomScreenSubtitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PageSubtitleTextStyle}" />
    <Style x:Key="RoomSectionTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}" />
    <Style x:Key="RoomFieldLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}" />
    <Style x:Key="RoomMutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}" />
    <Style x:Key="RoomValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ValueTextStyle}" />
    <Style x:Key="RoomStatusBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}" />
</ResourceDictionary>


