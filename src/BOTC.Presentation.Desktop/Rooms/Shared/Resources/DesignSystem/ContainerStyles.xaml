<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="ScreenCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource SpacingScreenPadding}" />
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSection}" />
        <Setter Property="Padding" Value="{StaticResource SpacingSectionPadding}" />
    </Style>

    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="{StaticResource SizeInputHeight}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ActionRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>

    <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBadgeBackground}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusBadge}" />
        <Setter Property="Padding" Value="{StaticResource SpacingBadgePadding}" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PlayerCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSection}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="BusyProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="8" />
        <Setter Property="IsIndeterminate" Value="True" />
        <Setter Property="Foreground" Value="{StaticResource BrushBusy}" />
    </Style>

    <Style x:Key="RoomScreenCardStyle" TargetType="Border" BasedOn="{StaticResource ScreenCardStyle}" />
    <Style x:Key="RoomSectionCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}" />
    <Style x:Key="RoomTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}" />
    <Style x:Key="RoomActionRowStyle" TargetType="StackPanel" BasedOn="{StaticResource ActionRowStyle}" />
    <Style x:Key="RoomStatusBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}" />
    <Style x:Key="RoomPlayerCardStyle" TargetType="Border" BasedOn="{StaticResource PlayerCardStyle}" />
    <Style x:Key="RoomBusyProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource BusyProgressBarStyle}" />
</ResourceDictionary>

