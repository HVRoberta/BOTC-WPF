<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.Shared.Controls.BusyIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel Visibility="{Binding IsBusy, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Margin="0,0,0,8"
                   Foreground="{StaticResource RoomMutedForegroundBrush}"
                   Text="{Binding Text, ElementName=Root}"
                   TextWrapping="Wrap" />
        <ProgressBar Style="{StaticResource RoomBusyProgressBarStyle}" />
    </StackPanel>
</UserControl>

