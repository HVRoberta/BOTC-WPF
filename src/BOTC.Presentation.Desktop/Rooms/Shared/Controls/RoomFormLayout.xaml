<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.Shared.Controls.RoomFormLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             x:Name="Root">
    <Border Style="{StaticResource RoomScreenCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource RoomScreenTitleTextStyle}"
                           Text="{Binding Title, ElementName=Root}" />
                <TextBlock Style="{StaticResource RoomScreenSubtitleTextStyle}"
                           Text="{Binding Subtitle, ElementName=Root}" />
            </StackPanel>

            <ContentPresenter Grid.Row="1"
                              Margin="0,24,0,0"
                              Content="{Binding FormContent, ElementName=Root}" />

            <ContentPresenter Grid.Row="2"
                              Margin="0,24,0,0"
                              Content="{Binding ActionContent, ElementName=Root}" />

            <StackPanel Grid.Row="3"
                        Margin="0,24,0,0">
                <controls:StateBanner Message="{Binding MessageText, ElementName=Root}"
                                      Kind="{Binding MessageKind, ElementName=Root}"
                                      Show="{Binding HasMessage, ElementName=Root}" />
                <controls:BusyIndicator Margin="0,12,0,0"
                                        Text="{Binding BusyText, ElementName=Root}"
                                        IsBusy="{Binding IsBusy, ElementName=Root}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>


