<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.CreateRoom.CreateRoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="420">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Create Room" />

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,4"
                   Text="Host display name" />
        <TextBox Grid.Row="2"
                 Margin="0,22,0,0"
                 Text="{Binding HostDisplayName, UpdateSourceTrigger=PropertyChanged}" />

        <Button Grid.Row="4"
                Height="34"
                HorizontalAlignment="Left"
                Padding="20,0"
                Command="{Binding CreateRoomCommand}"
                Content="Create room" />

        <TextBlock Grid.Row="6"
                   Foreground="IndianRed"
                   Text="{Binding ErrorMessage}" />

        <ProgressBar Grid.Row="7"
                     Margin="0,16,0,0"
                     Height="8"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</UserControl>

