<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.CreateRoom.CreateRoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sharedControls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="360"
             d:DesignWidth="520">
    <sharedControls:RoomFormLayout Title="Create room"
                                   Subtitle="Start a new room and enter the lobby as the host."
                                   MessageText="{Binding ScreenMessage}"
                                   MessageKind="{Binding ScreenMessageKind}"
                                   HasMessage="{Binding HasScreenMessage}"
                                   BusyText="{Binding BusyText}"
                                   IsBusy="{Binding IsBusy}">
        <sharedControls:RoomFormLayout.FormContent>
            <StackPanel>
                <TextBlock Style="{StaticResource RoomFieldLabelTextStyle}"
                           Text="Host display name" />
                <TextBox Style="{StaticResource RoomTextBoxStyle}"
                         Text="{Binding HostDisplayName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </sharedControls:RoomFormLayout.FormContent>

        <sharedControls:RoomFormLayout.ActionContent>
            <StackPanel Style="{StaticResource RoomActionRowStyle}">
                <Button Margin="0,0,12,0"
                        Style="{StaticResource RoomPrimaryButtonStyle}"
                        Command="{Binding CreateRoomCommand}"
                        Content="Create room" />
                <Button Style="{StaticResource RoomSecondaryButtonStyle}"
                        Command="{Binding NavigateToJoinRoomCommand}"
                        Content="Join existing room" />
            </StackPanel>
        </sharedControls:RoomFormLayout.ActionContent>
    </sharedControls:RoomFormLayout>
</UserControl>

