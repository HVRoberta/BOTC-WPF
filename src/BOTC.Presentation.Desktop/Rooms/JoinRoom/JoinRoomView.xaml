<UserControl x:Class="BOTC.Presentation.Desktop.Rooms.JoinRoom.JoinRoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sharedControls="clr-namespace:BOTC.Presentation.Desktop.Rooms.Shared.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="520">
    <sharedControls:RoomFormLayout Title="Join room"
                                   Subtitle="Enter a room code and the display name you want to use in the lobby."
                                   MessageText="{Binding ScreenMessage}"
                                   MessageKind="{Binding ScreenMessageKind}"
                                   HasMessage="{Binding HasScreenMessage}"
                                   BusyText="{Binding BusyText}"
                                   IsBusy="{Binding IsBusy}">
        <sharedControls:RoomFormLayout.FormContent>
            <StackPanel>
                <TextBlock Style="{StaticResource RoomFieldLabelTextStyle}"
                           Text="Room code" />
                <TextBox Style="{StaticResource RoomTextBoxStyle}"
                         CharacterCasing="Upper"
                         MaxLength="6"
                         Text="{Binding RoomCode, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,18,0,6"
                           Style="{StaticResource RoomFieldLabelTextStyle}"
                           Text="Display name" />
                <TextBox Style="{StaticResource RoomTextBoxStyle}"
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </sharedControls:RoomFormLayout.FormContent>

        <sharedControls:RoomFormLayout.ActionContent>
            <StackPanel Style="{StaticResource RoomActionRowStyle}">
                <Button Margin="0,0,12,0"
                        Style="{StaticResource RoomPrimaryButtonStyle}"
                        Command="{Binding JoinRoomCommand}"
                        Content="Join room" />
                <Button Style="{StaticResource RoomSecondaryButtonStyle}"
                        Command="{Binding BackToCreateRoomCommand}"
                        Content="Back to create room" />
            </StackPanel>
        </sharedControls:RoomFormLayout.ActionContent>
    </sharedControls:RoomFormLayout>
</UserControl>

