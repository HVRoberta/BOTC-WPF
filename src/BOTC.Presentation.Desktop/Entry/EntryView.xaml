<Window x:Class="BOTC.Presentation.Desktop.Entry.EntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:BOTC.Presentation.Desktop.Entry.Shared.Controls"
        xmlns:local="clr-namespace:BOTC.Presentation.Desktop.Entry"
        mc:Ignorable="d"
        Title="EntryView" Height="450" Width="800">
    <Grid Margin="0,30,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>        
            <ColumnDefinition Width="40"/>        
            <ColumnDefinition Width="Auto"/>        
        </Grid.ColumnDefinitions>
        
        <controls:WaxSealButton Grid.Column="0" 
                                 Width="220" 
                                 Height="220" 
                                 TopText="HOST GAME"
                                 BottomText="HOST GAME"
                                 BackgroundImage="/BOTC.Presentation.Desktop;component/Entry/Shared/Assets/host-seal.png"
                                 GlowBrush="#66FF4040"
                                 Foreground="#E8C26A"
                                 BorderBrushColor="#E8C26A"
                                 Command="{Binding HostGameCommand}" />
        
        <controls:WaxSealButton Grid.Column="2" 
                                Width="220" 
                                Height="220" 
                                TopText="JOIN GAME"
                                BottomText="JOIN GAME"
                                BackgroundImage="/BOTC.Presentation.Desktop;component/Entry/Shared/Assets/join-seal.png"
                                GlowBrush="#6640A0FF"
                                Foreground="#D9D9D9"
                                BorderBrushColor="#AAB7C8"
                                FallbackFill="#2B2E3A"
                                Command="{Binding JoinGameCommand}" />
    </Grid>
</Window>
