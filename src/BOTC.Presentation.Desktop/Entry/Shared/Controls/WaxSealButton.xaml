<UserControl x:Class="BOTC.Presentation.Desktop.Entry.Shared.Controls.WaxSealButton"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BOTC.Presentation.Desktop.Entry.Shared.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Button Command="{Binding Command, ElementName=Root}"
                CommandParameter="{Binding CommandParameter, ElementName=Root}"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Padding="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                     <Grid Width="{Binding Width, ElementName=Root}"
                           Height="{Binding Height, ElementName=Root}">
                         
                         <!-- Glow -->
                        <Ellipse x:Name="GlowEllipse" 
                                 Width="{Binding Width, ElementName=Root}"
                                 Height="{Binding Height, ElementName=Root}"
                                 Fill="{Binding GlowBrush, ElementName=Root}"
                                 Opacity="0.0" />
                         
                        <!-- Main seal image -->
                        <Ellipse Width="{Binding Width, ElementName=Root}"
                                 Height="{Binding Height, ElementName=Root}">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding BackgroundImage, ElementName=Root}"
                                            Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                        
                         <!-- Fallback circle if no image -->
                        <Ellipse Width="{Binding Width, ElementName=Root}"
                                 Height="{Binding Height, ElementName=Root}"
                                 Fill="{Binding FallbackFill, ElementName=Root}"
                                 Stroke="{Binding BorderBrushColor, ElementName=Root}"
                                 StrokeThickness="3"
                                 Opacity="0.35" />
                         
                        <!-- Inner layout -->
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0"
                                       Text="{Binding TopText, ElementName=Root}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{Binding ForegroundBrush, ElementName=Root}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            
                            <Image Grid.Row = "1" 
                                   Source="{Binding CenterImage, ElementName=Root}"
                                   Width="70"
                                   Height="70"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            
                            <TextBlock Grid.Row="2"
                                       Text="{Binding BottomText, ElementName=Root}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{Binding ForegroundBrush, ElementName=Root}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                        </Grid>
                     </Grid>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GlowEllipse" Property="Opacity" Value="0.35" />
                        </Trigger>    
                        
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="GlowEllipse" Property="Opacity" Value="0.55" />
                        </Trigger>  
                        
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>  
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
